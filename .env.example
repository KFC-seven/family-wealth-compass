# ============================================================
# 家庭财富罗盘 (Family Wealth Compass) — 环境变量配置
# ============================================================
# 复制此文件为 .env 后使用:  cp .env.example .env
# 本地开发默认值无需修改即可使用 Docker PostgreSQL。
# ============================================================

# --- 数据库 (必需) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/family_wealth?schema=public"

# --- Next.js ---
NEXT_PUBLIC_API_BASE=""
NEXT_PUBLIC_USE_API=false

# --- Prisma (可选) ---
# 中国大陆加速 Prisma Engine 下载（取消注释即可启用）
# PRISMA_ENGINES_MIRROR="https://cdn.npmmirror.com/binaries/prisma"

# --- 行情数据源 (Phase 8) ---
MARKET_DATA_MODE="mock"               # mock | mixed | real
MARKET_DATA_ENABLE_EASTMONEY_FUND=false
MARKET_DATA_ENABLE_SINA_FINANCE=false
MARKET_DATA_ENABLE_TUSHARE=false
TUSHARE_TOKEN=""

# --- 定时任务 (Phase 8) ---
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE="Asia/Shanghai"
JOB_API_SECRET=""

# --- 认证 (Phase 12) ---
AUTH_ENABLED=false
AUTH_SESSION_COOKIE_NAME="fwc_session"
AUTH_SESSION_MAX_AGE_DAYS=30
AUTH_REQUIRE_HTTPS=false
AUTH_DEV_ALLOW_SEED_LOGIN=true
SEED_ADMIN_EMAIL="admin@example.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="家庭管理员"

# --- 文件上传 (Phase 10) ---
UPLOAD_ENABLED=false
UPLOAD_STORAGE_PROVIDER="local"       # local | aliyun-oss
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp"
LOCAL_UPLOAD_DIR="./uploads"
UPLOAD_API_SECRET=""

# --- OCR (Phase 10) ---
OCR_PROVIDER="mock"                   # mock | aliyun | tencent | paddle
OCR_ENABLED=false
OCR_CONFIDENCE_THRESHOLD=0.8

# --- AI 简报生成 (Phase 11) ---
AI_PROVIDER="mock"                    # mock | deepseek | aliyun-bailian | openai-compatible
AI_ENABLED=false
AI_MODEL="deepseek-chat"
AI_BASE_URL=""
AI_API_KEY=""
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_RETRIES=2
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
ALIYUN_BAILIAN_API_KEY=""
ALIYUN_BAILIAN_BASE_URL=""
OPENAI_COMPATIBLE_API_KEY=""
OPENAI_COMPATIBLE_BASE_URL=""
OPENAI_COMPATIBLE_MODEL=""
DAILY_BRIEF_ENABLED=false
DAILY_BRIEF_TIMEZONE="Asia/Shanghai"
DAILY_BRIEF_INCLUDE_AI_ADVICE=true
DAILY_BRIEF_MAX_NEWS_ITEMS=20

# --- 微信推送 (Phase 11) ---
WECHAT_PUSH_ENABLED=false
WECHAT_PUSH_PROVIDER="mock"           # mock | wecom-bot | server-chan
WECHAT_WORK_WEBHOOK_URL=""
SERVER_CHAN_SEND_KEY=""
WECHAT_PUSH_INCLUDE_TOTAL_ASSETS=false
WECHAT_PUSH_INCLUDE_MEMBER_DETAILS=false
WECHAT_PUSH_INCLUDE_AI_ADVICE=true
WECHAT_PUSH_ONLY_HIGH_RISK=false
BRIEF_API_SECRET=""
PUSH_API_SECRET=""

# --- 阿里云 (Phase 10: 未来 OSS / OCR) ---
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_REGION=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ENDPOINT=""
ALIYUN_OCR_ENDPOINT=""

# --- 未来集成 (暂不填写) ---
DEEPSEEK_API_KEY=""
WECHAT_WORK_WEBHOOK_URL=""
SERVER_CHAN_SEND_KEY=""
