# ============================================================
# 家庭财富罗盘 (Family Wealth Compass) — 环境变量配置
# ============================================================
# 复制此文件为 .env 后使用:  cp .env.example .env
# 本地开发默认值无需修改即可使用 Docker PostgreSQL。
# ============================================================

# --- 数据库 (必需) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/family_wealth?schema=public"

# --- Next.js ---
NEXT_PUBLIC_API_BASE=""
NEXT_PUBLIC_USE_API=false

# --- Prisma (可选) ---
# 中国大陆加速 Prisma Engine 下载（取消注释即可启用）
# PRISMA_ENGINES_MIRROR="https://cdn.npmmirror.com/binaries/prisma"

# --- 行情数据源 (Phase 8) ---
MARKET_DATA_MODE="mock"               # mock | mixed | real
MARKET_DATA_ENABLE_EASTMONEY_FUND=false
MARKET_DATA_ENABLE_TUSHARE=false
TUSHARE_TOKEN=""

# --- 定时任务 (Phase 8) ---
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE="Asia/Shanghai"
JOB_API_SECRET=""

# --- 未来集成 (暂不填写) ---
DEEPSEEK_API_KEY=""
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_OSS_BUCKET=""
WECHAT_WORK_WEBHOOK_URL=""
SERVER_CHAN_SEND_KEY=""
