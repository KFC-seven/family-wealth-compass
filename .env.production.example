# ============================================================
# 家庭财富罗盘 — 生产环境变量模板
# 复制为 .env.production 后修改所有 CHANGE_ME 值
# ============================================================

NODE_ENV=production
PORT=3000

# --- 数据库 ---
DATABASE_URL="postgresql://family_wealth:CHANGE_ME@127.0.0.1:5432/family_wealth?schema=public"

# --- Next.js ---
NEXT_PUBLIC_API_BASE=""
NEXT_PUBLIC_USE_API=true

# --- 认证 (生产必开) ---
AUTH_ENABLED=true
AUTH_SESSION_COOKIE_NAME="fwc_session"
AUTH_SESSION_MAX_AGE_DAYS=30
AUTH_REQUIRE_HTTPS=true
AUTH_DEV_ALLOW_SEED_LOGIN=false
SEED_ADMIN_EMAIL="admin@example.local"
SEED_ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
SEED_ADMIN_NAME="家庭管理员"

# --- 文件上传 ---
UPLOAD_ENABLED=true
UPLOAD_STORAGE_PROVIDER="local"
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp"
LOCAL_UPLOAD_DIR="./uploads"
UPLOAD_API_SECRET="CHANGE_ME"

# --- OCR ---
OCR_PROVIDER="mock"
OCR_ENABLED=false
OCR_CONFIDENCE_THRESHOLD=0.8

# --- 行情 ---
MARKET_DATA_MODE="mock"
MARKET_DATA_ENABLE_EASTMONEY_FUND=false
MARKET_DATA_ENABLE_SINA_FINANCE=false
MARKET_DATA_ENABLE_TUSHARE=false
TUSHARE_TOKEN=""

# --- 定时任务 ---
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE="Asia/Shanghai"
JOB_API_SECRET="CHANGE_ME"

# --- AI 简报 ---
AI_PROVIDER="mock"
AI_ENABLED=false
AI_MODEL="deepseek-chat"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DAILY_BRIEF_ENABLED=true
DAILY_BRIEF_TIMEZONE="Asia/Shanghai"
DAILY_BRIEF_INCLUDE_AI_ADVICE=true
BRIEF_API_SECRET="CHANGE_ME"

# --- 微信推送 ---
WECHAT_PUSH_ENABLED=false
WECHAT_PUSH_PROVIDER="mock"
WECHAT_WORK_WEBHOOK_URL=""
SERVER_CHAN_SEND_KEY=""
WECHAT_PUSH_INCLUDE_TOTAL_ASSETS=false
WECHAT_PUSH_INCLUDE_MEMBER_DETAILS=false
WECHAT_PUSH_INCLUDE_AI_ADVICE=true
WECHAT_PUSH_ONLY_HIGH_RISK=false
PUSH_API_SECRET="CHANGE_ME"

# --- 阿里云 (未来集成) ---
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_REGION=""
ALIYUN_OSS_BUCKET=""
ALIYUN_OSS_ENDPOINT=""
ALIYUN_OCR_ENDPOINT=""
